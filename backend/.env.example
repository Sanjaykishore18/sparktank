# Server
PORT=5000
NODE_ENV=production

# MongoDB (use MongoDB Atlas connection string)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/speakx?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_strong_random_jwt_secret_here
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Gemini API
GEMINI_API_KEY=your_gemini_api_key

# Frontend URL (Vercel deployment URL — comma-separated for multiple origins)
CLIENT_URL=https://your-app.vercel.app
